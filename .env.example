DATABASE_URL=postgres://ocm:ocm@manager-postgres:5432/ocm?sslmode=disable
REDIS_ADDR=manager-redis:6379
REDIS_PASSWORD=123456
NEWAPI_BASE_URL=http://new-api:3000
OLLAMA_BASE_URL=http://ollama:11434
MANAGER_POSTGRES_PORT=15432
MANAGER_REDIS_PORT=6379
NEWAPI_REDIS_PORT=6380
NEWAPI_PORT=3000
# new-api 个人设置 → 安全设置 → 系统访问令牌（必填，否则所有 admin 接口 401）
# 注意：不是「令牌」页的 sk- 形式 API token，那个只能调模型推理
NEWAPI_ADMIN_TOKEN=
# admin 用户 id，对应 new-api 要求的 New-Api-User header；admin/admin123! 默认 id=1
NEWAPI_ADMIN_USER_ID=1
# OpenClaw 容器内嵌 pi-coding-agent 的模型配置。base_url 必须含 /v1（OpenAI 兼容路径）。
# default_model 必须是 new-api 渠道里实际可路由的模型名（如 ollama 的 qwen2.5:0.5b）。
OPENCLAW_LLM_BASE_URL=http://new-api:3000/v1
OPENCLAW_LLM_DEFAULT_PROVIDER=openai
OPENCLAW_LLM_DEFAULT_MODEL=qwen2.5:0.5b
# 注入容器 OPENAI_API_KEY 的全局 sk- token：
# 1. 浏览器登录 http://localhost:3000 (admin/admin123!)
# 2. 「令牌」页 → 「添加令牌」→ unlimited / 永不过期 → 复制完整 sk- 字符串
# 3. 粘贴到下面（all dev apps 共用此 token）
OPENCLAW_LLM_OPENAI_API_KEY=
OLLAMA_PORT=11434
MANAGER_API_PORT=8080
MANAGER_WEB_PORT=5173
RUNTIME_AGENT_GRPC_PORT=7001
RUNTIME_AGENT_HTTP_PORT=7002
