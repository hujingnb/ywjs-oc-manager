# manager 本地 PostgreSQL 暴露到宿主机的端口，方便数据库工具连接。
MANAGER_POSTGRES_PORT=15432

# manager 本地 Redis 暴露到宿主机的端口。
MANAGER_REDIS_PORT=6379

# new-api 本地 Redis 暴露到宿主机的端口，避免与 manager Redis 混用。
NEWAPI_REDIS_PORT=6380

# new-api HTTP 服务端口，manager 和浏览器可通过宿主机访问。
NEWAPI_PORT=3000

# Ollama HTTP 服务端口，用于 new-api 配置模型渠道。
OLLAMA_PORT=11434

# RAGFlow HTTP API 端口，manager 本地容器通过 http://ragflow:9380 访问，宿主机通过该端口访问。
RAGFLOW_HTTP_PORT=9380

# RAGFlow Web 控制台端口；管理员在这里手工配置 existing new-api + DeepSeek 模型供应商。
RAGFLOW_WEB_HTTP_PORT=8088

# RAGFlow Admin 服务端口。
RAGFLOW_ADMIN_HTTP_PORT=9381

# RAGFlow MySQL 暴露到宿主机的端口，避免占用本机 3306。
RAGFLOW_MYSQL_PORT=13306

# RAGFlow Redis/Valkey 暴露到宿主机的端口，避免和 manager/new-api Redis 冲突。
RAGFLOW_REDIS_PORT=16379

# RAGFlow MinIO API 与控制台端口。
RAGFLOW_MINIO_PORT=19000
RAGFLOW_MINIO_CONSOLE_PORT=19001

# RAGFlow Elasticsearch 端口。
RAGFLOW_ES_PORT=19200

# RAGFlow 本地镜像与默认依赖密码；仅用于本地调试，生产必须在 deploy/ragflow/.env 中改强密码。
RAGFLOW_IMAGE=infiniflow/ragflow:v0.25.6
RAGFLOW_MYSQL_PASSWORD=infini_rag_flow
RAGFLOW_REDIS_PASSWORD=infini_rag_flow
RAGFLOW_MINIO_USER=rag_flow
RAGFLOW_MINIO_PASSWORD=infini_rag_flow
RAGFLOW_ELASTIC_PASSWORD=infini_rag_flow

# manager-api 本地 HTTP 端口。
MANAGER_API_PORT=8080

# manager-web Vite dev server 端口。
MANAGER_WEB_PORT=5173

# runtime-agent gRPC 控制面端口。
RUNTIME_AGENT_GRPC_PORT=7001

# runtime-agent HTTP 健康检查和文件接口端口。
RUNTIME_AGENT_HTTP_PORT=7002

#================================================
# Makefile - 线上服务器临时 SSH 调试变量
# 推荐使用 SSH key、ssh-agent 或堡垒机；下方 PASS 变量仅兼容历史 sshpass 目标。
# 真实连接信息只能写入 gitignored 的本地 .env，严禁提交真实密码。
#================================================
PROD_MANAGER_SSH_HOST=    # manager 公网 IP
PROD_MANAGER_SSH_PORT=    # manager SSH 端口（非默认 22 时填写）
PROD_MANAGER_SSH_USER=    # manager SSH 用户，生产不建议使用 root
PROD_MANAGER_SSH_PASS=    # 兼容历史 sshpass 目标；优先使用 SSH key / agent

# agent-1 无公网 IP，make ssh-agent1 会先连 manager 再经内网跳转到 agent-1
PROD_AGENT1_SSH_HOST=     # agent-1 内网 IP
PROD_AGENT1_SSH_USER=     # agent-1 SSH 用户，生产不建议使用 root
PROD_AGENT1_SSH_PASS=     # 兼容历史 sshpass 目标；优先使用 SSH key / agent
