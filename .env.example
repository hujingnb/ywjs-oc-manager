#================================================
# Makefile - 线上 manager MySQL 连接（make prod-db）
# 经 util namespace 的 mysql 客户端 pod 跳板连接外部托管的线上 MySQL。
# 真实口令只能写入 gitignored 的本地 .env，严禁提交。
#================================================
PROD_DB_HOST=            # 线上 MySQL 主机（外部托管实例地址）
PROD_DB_PORT=3306        # MySQL 端口，默认 3306
PROD_DB_USER=            # 数据库账号
PROD_DB_PASS=            # 数据库口令；仅写入本地 .env，勿提交
PROD_DB_NAME=manager     # 库名，默认 manager
