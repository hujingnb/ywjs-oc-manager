# Compose 项目名会影响容器和网络前缀；每台 runtime node 通常保持默认即可。
COMPOSE_PROJECT_NAME=oc-runtime-agent

# runtime-agent 生产镜像。使用具体版本 tag（如 v1.0.0）或 @sha256: digest，禁用 latest，
# 确保节点滚动升级和回滚可复现。镜像由 runtime/agent/Dockerfile 构建后推到 aliyun ACR。
OC_RUNTIME_AGENT_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_app/oc-manager-agent:CHANGE_ME_TAG

# gRPC 端口用于 manager 与 runtime-agent 控制面通信。
RUNTIME_AGENT_GRPC_PORT=7001

# HTTP 端口用于健康检查、文件访问或本地管理接口。
RUNTIME_AGENT_HTTP_PORT=7002

# 容器时区；日志与 manager 侧事件时间保持一致。
TZ=Asia/Shanghai
