# Compose 项目名会影响容器和网络前缀；同一宿主多套 Ollama 时必须保持唯一。
COMPOSE_PROJECT_NAME=oc-ollama

# Ollama 生产镜像。使用具体版本 tag 或 @sha256: digest，禁用 latest，
# 避免 GPU 节点重启后镜像内容漂移。
# 原 docker.io/ollama/ollama:<tag> → 现 crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/ollama:<tag>
OLLAMA_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/ollama:CHANGE_ME_TAG

# 对外服务端口；new-api 的模型渠道会访问该端口或其上层反代地址。
OLLAMA_PORT=11434

# Ollama 容器内监听地址；生产通常保持 0.0.0.0 以便 Docker 端口映射生效。
OLLAMA_HOST=0.0.0.0:11434

# 允许访问 Ollama 的来源，建议只填写 new-api 或可信反代域名。
OLLAMA_ORIGINS=https://new-api.example.com

# 容器时区；用于日志和模型服务排障。
TZ=Asia/Shanghai
