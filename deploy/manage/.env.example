# Compose 项目名会影响容器、网络和默认资源前缀；同一宿主多套部署时必须保持唯一。
COMPOSE_PROJECT_NAME=oc-manage

# manager-api 生产镜像必须固定到 @sha256 digest，避免 rollout 和回滚时镜像内容漂移。
OCM_MANAGER_IMAGE=ghcr.io/your-org/openclaw-manager@sha256:CHANGE_ME_MANAGER_IMAGE_DIGEST

# manager-web 前端生产镜像 digest。
OCM_WEB_IMAGE=ghcr.io/your-org/openclaw-manager-web@sha256:CHANGE_ME_WEB_IMAGE_DIGEST

# manager PostgreSQL 生产镜像 digest。
MANAGER_POSTGRES_IMAGE=postgres@sha256:CHANGE_ME_POSTGRES_IMAGE_DIGEST

# manager Redis 生产镜像 digest。
MANAGER_REDIS_IMAGE=redis@sha256:CHANGE_ME_REDIS_IMAGE_DIGEST

# manager nginx 生产镜像 digest。
MANAGER_NGINX_IMAGE=nginx@sha256:CHANGE_ME_NGINX_IMAGE_DIGEST

# nginx 对外 HTTP 监听端口。
MANAGER_HTTP_PORT=80

# nginx 对外 HTTPS 监听端口。
MANAGER_HTTPS_PORT=443

# PostgreSQL 初始化用户名。
MANAGER_POSTGRES_USER=ocm

# PostgreSQL 原始密码，用于初始化数据库容器。
MANAGER_POSTGRES_PASSWORD=CHANGE_ME_MANAGER_POSTGRES_PASSWORD

# PostgreSQL URL 编码后的密码，用于写入 config/manager.yaml 的 database.url。
MANAGER_POSTGRES_DSN_PASSWORD=CHANGE_ME_URL_ENCODED_MANAGER_POSTGRES_PASSWORD

# manager 使用的 PostgreSQL 数据库名。
MANAGER_POSTGRES_DB=ocm

# Redis 原始密码；需要同步写入 config/manager.yaml 的 redis.password。
MANAGER_REDIS_PASSWORD=CHANGE_ME_MANAGER_REDIS_PASSWORD

# 容器时区；日志、数据库默认时间和排障时保持一致。
TZ=Asia/Shanghai
