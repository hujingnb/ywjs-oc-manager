# Compose 项目名会影响容器、网络和默认资源前缀；同一宿主多套部署时必须保持唯一。
COMPOSE_PROJECT_NAME=oc-manage

# manager-api 生产镜像。使用具体版本 tag（如 v1.0.0）或 @sha256: digest，禁用 latest，
# 避免 rollout / 回滚时镜像内容漂移。镜像由 cmd/server/Dockerfile 构建后推到 aliyun ACR。
OCM_MANAGER_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_app/oc-manager-api:CHANGE_ME_TAG

# manager-web 前端生产镜像。tag 通常与 OCM_MANAGER_IMAGE 同步，由 web/Dockerfile 构建。
OCM_WEB_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_app/oc-manager-web:CHANGE_ME_TAG

# manager PostgreSQL 生产镜像。
# 原 docker.io/library/postgres:17-alpine → 现 crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/postgres:17-alpine
MANAGER_POSTGRES_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/postgres:17-alpine

# manager Redis 生产镜像。
# 原 docker.io/library/redis:7 → 现 crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/redis:7
MANAGER_REDIS_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/redis:7

# manager nginx 生产镜像。
# 原 docker.io/library/nginx:1.27-alpine → 现 crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/nginx:1.27-alpine
MANAGER_NGINX_IMAGE=crpi-nu3ibz4f07feyghi.cn-beijing.personal.cr.aliyuncs.com/ywjs_public/nginx:1.27-alpine

# nginx 对外 HTTP 监听端口。
MANAGER_HTTP_PORT=80

# nginx 对外 HTTPS 监听端口。
MANAGER_HTTPS_PORT=443

# PostgreSQL 初始化用户名。
MANAGER_POSTGRES_USER=ocm

# PostgreSQL 原始密码，用于初始化数据库容器。
MANAGER_POSTGRES_PASSWORD=CHANGE_ME_MANAGER_POSTGRES_PASSWORD

# PostgreSQL URL 编码后的密码，用于写入 config/manager.yaml 的 database.url。
MANAGER_POSTGRES_DSN_PASSWORD=CHANGE_ME_URL_ENCODED_MANAGER_POSTGRES_PASSWORD

# manager 使用的 PostgreSQL 数据库名。
MANAGER_POSTGRES_DB=ocm

# Redis 原始密码；需要同步写入 config/manager.yaml 的 redis.password。
MANAGER_REDIS_PASSWORD=CHANGE_ME_MANAGER_REDIS_PASSWORD

# 容器时区；日志、数据库默认时间和排障时保持一致。
TZ=Asia/Shanghai
