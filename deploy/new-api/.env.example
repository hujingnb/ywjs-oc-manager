# Compose 项目名会影响容器、网络和默认资源前缀；同一宿主多套部署时必须保持唯一。
COMPOSE_PROJECT_NAME=oc-new-api

# new-api 生产镜像。使用具体版本 tag 或 @sha256: digest，禁用 latest，
# 避免重启或 pull 时拉到不同内容。走 docker.1ms.run 镜像加速 Docker Hub 拉取。
NEWAPI_IMAGE=docker.1ms.run/calciumion/new-api:CHANGE_ME_TAG

# PostgreSQL 生产镜像，走 docker.1ms.run 镜像加速 Docker Hub 拉取。
NEWAPI_POSTGRES_IMAGE=docker.1ms.run/library/postgres:17-alpine

# Redis 生产镜像，走 docker.1ms.run 镜像加速 Docker Hub 拉取。
NEWAPI_REDIS_IMAGE=docker.1ms.run/library/redis:7

# new-api 对外监听端口；通常由宿主 nginx/SLB 反代到该端口。
NEWAPI_PORT=3000

# new-api 节点标识，按生产节点命名调整。
NEWAPI_NODE_NAME=new-api-prod-1

# new-api 流式响应超时时间，单位为秒。
NEWAPI_STREAMING_TIMEOUT=600

# PostgreSQL 初始化用户名。
NEWAPI_POSTGRES_USER=root

# PostgreSQL 原始密码，用于初始化数据库容器。
NEWAPI_POSTGRES_PASSWORD=CHANGE_ME_NEWAPI_POSTGRES_PASSWORD

# PostgreSQL URL 编码后的密码，用于拼接 SQL_DSN。
NEWAPI_POSTGRES_DSN_PASSWORD=CHANGE_ME_URL_ENCODED_NEWAPI_POSTGRES_PASSWORD

# new-api 使用的 PostgreSQL 数据库名。
NEWAPI_POSTGRES_DB=new-api

# Redis 原始密码，用于服务端鉴权。
NEWAPI_REDIS_PASSWORD=CHANGE_ME_NEWAPI_REDIS_PASSWORD

# Redis URL 编码后的密码，用于拼接 REDIS_CONN_STRING。
NEWAPI_REDIS_URL_PASSWORD=CHANGE_ME_URL_ENCODED_NEWAPI_REDIS_PASSWORD

# 容器时区；日志、数据库默认时间和排障时保持一致。
TZ=Asia/Shanghai
