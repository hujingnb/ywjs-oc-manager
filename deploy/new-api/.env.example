# Compose 项目名会影响容器、网络和默认资源前缀；同一宿主多套部署时必须保持唯一。
COMPOSE_PROJECT_NAME=oc-new-api

# 生产镜像必须固定到 @sha256 digest，避免重启或 pull 时拉到不同内容。
NEWAPI_IMAGE=calciumion/new-api@sha256:CHANGE_ME_NEWAPI_IMAGE_DIGEST
NEWAPI_POSTGRES_IMAGE=postgres@sha256:CHANGE_ME_POSTGRES_IMAGE_DIGEST
NEWAPI_REDIS_IMAGE=redis@sha256:CHANGE_ME_REDIS_IMAGE_DIGEST

# new-api 对外监听端口；通常由宿主 nginx/SLB 反代到该端口。
NEWAPI_PORT=3000

# new-api 节点标识和流式响应超时时间，按生产节点命名调整。
NEWAPI_NODE_NAME=new-api-prod-1
NEWAPI_STREAMING_TIMEOUT=600

# PostgreSQL 初始化和连接参数。DSN 密码必须填写 URL 编码后的同一密码。
NEWAPI_POSTGRES_USER=root
NEWAPI_POSTGRES_PASSWORD=CHANGE_ME_NEWAPI_POSTGRES_PASSWORD
NEWAPI_POSTGRES_DSN_PASSWORD=CHANGE_ME_URL_ENCODED_NEWAPI_POSTGRES_PASSWORD
NEWAPI_POSTGRES_DB=new-api

# Redis 原始密码用于服务端鉴权，URL 密码用于写入 new-api Redis 连接串。
NEWAPI_REDIS_PASSWORD=CHANGE_ME_NEWAPI_REDIS_PASSWORD
NEWAPI_REDIS_URL_PASSWORD=CHANGE_ME_URL_ENCODED_NEWAPI_REDIS_PASSWORD

# 容器时区；日志、数据库默认时间和排障时保持一致。
TZ=Asia/Shanghai
