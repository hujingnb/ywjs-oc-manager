{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ocops Channel Status",
  "type": "object",
  "required": ["channel", "bound"],
  "properties": {
    "channel": { "type": "string" },
    "bound": { "type": "boolean" },
    "account_id": { "type": "string" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": { "bound": { "const": true } },
        "required": ["bound"]
      },
      "then": { "required": ["account_id"] }
    }
  ]
}
