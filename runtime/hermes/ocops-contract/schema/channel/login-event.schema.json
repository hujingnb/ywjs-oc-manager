{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ocops Channel Login Event",
  "oneOf": [
    {
      "type": "object",
      "required": ["event", "url"],
      "properties": {
        "event": { "const": "qrcode" },
        "url": { "type": "string" }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["event"],
      "properties": {
        "event": { "enum": ["bound", "timeout"] }
      },
      "additionalProperties": false
    },
    {
      "type": "object",
      "required": ["event", "reason"],
      "properties": {
        "event": { "const": "failed" },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    }
  ]
}
