{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ocops Error",
  "type": "object",
  "required": ["code", "message"],
  "properties": {
    "code": {
      "type": "string",
      "enum": [
        "BAD_REQUEST",
        "UNAUTHORIZED",
        "NOT_FOUND",
        "UNSUPPORTED",
        "HERMES_CLI_FAILED",
        "INTERNAL"
      ]
    },
    "message": { "type": "string" }
  },
  "additionalProperties": false
}
