{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ocops Skills Install Multipart Fields",
  "type": "object",
  "required": ["name", "archive"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/]+$",
      "not": { "enum": [".", ".."] }
    },
    "archive": {
      "description": "multipart file field containing a tar or zip archive",
      "type": "string",
      "contentEncoding": "binary"
    }
  },
  "additionalProperties": false
}
