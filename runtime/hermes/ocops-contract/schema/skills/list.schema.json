{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ocops Skills List",
  "type": "object",
  "required": ["skills"],
  "properties": {
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "managed", "builtin", "description"],
        "properties": {
          "name": { "type": "string" },
          "managed": { "type": "boolean" },
          "builtin": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
