#!/usr/bin/env bash
# oc-sync — sidecar 入口：循环把 /opt/data 产物增量同步回 S3。
# 用 bootstrap 的 s3_write 凭证写 apps/<id>/ 前缀；临时凭证临近过期会自调 bootstrap 续期，
# 长期凭证（目标存储不支持 STS 时）的过期时间为远未来，续期分支不会触发。
# workspace、sessions、weixin、长期记忆、自创 skill、cron 与 variant 状态增量同步（无 --delete）
# 每 OC_SYNC_INTERVAL 秒一次；sqlite 一致性快照每 OC_SQLITE_INTERVAL 秒一次。OC_SYNC_ONCE=1 时只跑一轮后退出，供测试。
set -euo pipefail
# shellcheck source=/usr/local/bin/oc-lib.sh
# shellcheck disable=SC1091
source /usr/local/bin/oc-lib.sh

require_env OC_CONTROL_TOKEN OC_BOOTSTRAP_URL
DATA_DIR=${OC_DATA_DIR:-/opt/data}
WS_INTERVAL=${OC_SYNC_INTERVAL:-8}
DB_INTERVAL=${OC_SQLITE_INTERVAL:-30}
SKEW=${OC_CRED_SKEW:-300}

bs=$(mktemp)
trap 'rm -f "$bs"' EXIT
expiry=0
last_db=0

# ensure_creds 首次或临近过期时拉 bootstrap、写 S3 凭证、解析 S3 参数、刷新过期时间。
# expiry 与 last_db 是有意的脚本级状态，函数内赋值为预期行为。
ensure_creds() {
  if [ "$expiry" -eq 0 ] || needs_refresh "$expiry" "$SKEW"; then
    fetch_bootstrap "$bs"
    write_aws_credentials "$bs"
    export_s3_env "$bs"
    expiry=$(creds_expiry_epoch "$bs")
    log "S3 凭证已刷新，过期 $(date -u -d "@$expiry" +%FT%TZ)"
  fi
}

# run_once 跑一轮：确保凭证新鲜 → 同步目录/单文件运行时状态 → 到点则备份 sqlite。
run_once() {
  ensure_creds
  sync_workspace_up "$DATA_DIR"
  sync_sessions_up "$DATA_DIR"
  sync_weixin_up "$DATA_DIR"
  sync_longterm_memory_up "$DATA_DIR"
  sync_user_skills_up "$DATA_DIR"
  sync_cron_up "$DATA_DIR"
  sync_oc_state_up "$DATA_DIR"
  local now
  now=$(date -u +%s)
  if [ $((now - last_db)) -ge "$DB_INTERVAL" ]; then
    backup_sqlite_up "$DATA_DIR"
    backup_kanban_db_up "$DATA_DIR"
    last_db=$now
  fi
}

if [ "${OC_SYNC_ONCE:-0}" = "1" ]; then
  # 测试模式：跑一轮完整持久化同步，并强制做一次 sqlite 备份，便于断言。
  ensure_creds
  sync_workspace_up "$DATA_DIR"
  sync_sessions_up "$DATA_DIR"
  sync_weixin_up "$DATA_DIR"
  sync_longterm_memory_up "$DATA_DIR"
  sync_user_skills_up "$DATA_DIR"
  sync_cron_up "$DATA_DIR"
  sync_oc_state_up "$DATA_DIR"
  backup_sqlite_up "$DATA_DIR"
  backup_kanban_db_up "$DATA_DIR"
  log "oc-sync 单轮完成（OC_SYNC_ONCE）"
  exit 0
fi

log "oc-sync 启动：运行时目录每 ${WS_INTERVAL}s，sqlite 每 ${DB_INTERVAL}s，凭证提前 ${SKEW}s 续期"
while :; do
  run_once
  sleep "$WS_INTERVAL"
done
